#!/bin/bash

# Print tmux list-windows as a pretty table

if ! tmux has-session 2>/dev/null; then
   printf "No tmux session found.\n"
   exit 1
fi

mapfile -t lines < <(tmux list-windows -a -F "#{session_name},#{window_index},#{window_name}")

session_col_name="SESSION"
win_col_name="WINDOW"

max_session_len=${#session_col_name}
max_win_len=${#win_col_name}

for line in "${lines[@]}"; do
   IFS=',' read -r session win_index win_name <<< "$line"

   session_len=${#session}
   [[ $session_len -gt $max_session_len ]] && max_session_len=$session_len

   win_len=$((${#win_index} + 1 + ${#win_name}))
   [[ $win_len -gt $max_win_len ]] && max_win_len=$win_len
done

session_col_width=$((max_session_len + 2))
win_col_width=$((max_win_len + 2))

printf "%-${session_col_width}s %-${win_col_width}s\n" " ""$session_col_name"" " " ""$win_col_name"" "

printf "%s %s\n" \
  "$(head -c $session_col_width < <(printf '%*s' "$session_col_width" '' | tr ' ' '-'))" \
  "$(head -c $win_col_width < <(printf '%*s' "$win_col_width" '' | tr ' ' '-'))"

prev_session=""
for line in "${lines[@]}"; do
   IFS=',' read -r session win_index win_name <<< "$line"

   if [[ "$session" == "$prev_session" ]]; then
      session=""
   else
      prev_session="$session"
   fi

   printf "%-${session_col_width}s %-${win_col_width}s\n" " ""$session"" " " ""$win_index"":""$win_name"" "
done
