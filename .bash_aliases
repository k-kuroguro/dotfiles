alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

alias g='git'

alias ls='ls --color=auto'
alias ll='ls -alF'
alias la='ls -A'

alias grep='grep --color=auto'

alias va='source .venv/bin/activate'
alias bashrc='source ~/.bashrc'

alias untar='tar -xvf'
alias untargz='tar -zxvf'

alias uvt='uv run task'

alias nsmi='nvidia-smi'
alias csmi='cluster-smi'
